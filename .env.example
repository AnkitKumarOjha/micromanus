# ---------------------------------------------------------------------------
# MicroManus environment variables
# Copy to .env.local for local dev, and set the same keys in Vercel → Settings
# → Environment Variables for production. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# Public site URL. Local: http://localhost:3000 . Prod: https://<project>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DodoPayments → Settings → API keys / Webhooks
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# The one-time $5 product created in the Dodo dashboard.
DODO_PRODUCT_ID_5_CREDITS=

# Brave Search API → https://api.search.brave.com (free tier)
BRAVE_SEARCH_API_KEY=

# 32-byte key used to encrypt user-submitted LLM API keys at rest.
# Generate one with:  openssl rand -base64 32
ENCRYPTION_KEY=

# Coupon that unlocks the paywall and grants 5 credits (one-time per account).
PAYWALL_COUPON_CODE=SID_DRDROID
